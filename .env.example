# ================================================================
#  CloudGuard AI - Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit your .env file to Git!
# ================================================================

# ── AI Provider ─────────────────────────────────────────────────
# Choose: "anthropic" or "openrouter"
# Recommendation: use "openrouter" — it has FREE models, no card needed.
AI_PROVIDER=openrouter

# ── Anthropic (only needed if AI_PROVIDER=anthropic) ────────────
# Paid API — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key-here

# ── OpenRouter (only needed if AI_PROVIDER=openrouter) ──────────
# FREE to sign up — no credit card needed.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# ── Which AI model to use ────────────────────────────────────────
# OpenRouter supports 300+ models. Just paste the model ID below.
#
# HOW TO FIND MORE MODELS:
#   1. Go to https://openrouter.ai/models
#   2. Filter by "Free" to see all free models
#   3. Click any model -> copy the model ID shown on its page
#   4. Paste it as OPENROUTER_MODEL=<model-id>
#
# FREE models (no cost, no credit card):
#   meta-llama/llama-3.3-70b-instruct:free     <- default, great all-around
#   google/gemma-3-27b-it:free                 <- fast, good quality
#   deepseek/deepseek-r1:free                  <- great at reasoning
#   qwen/qwen3-30b-a3b:free                    <- strong technical answers
#   mistralai/mistral-small-3.1-24b-instruct:free
#   nvidia/llama-3.1-nemotron-70b-instruct:free
#
# PAID models (better quality, costs fractions of a cent per scan):
#   openai/gpt-4o-mini                         <- fast + sharp, ~$0.001/scan
#   anthropic/claude-3-haiku                   <- great reasoning, cheap
#   google/gemini-flash-1.5                    <- very fast, affordable
#   meta-llama/llama-3.1-405b-instruct         <- largest Llama, high quality
#
# TIP: Free models are perfectly fine for learning and demos.
#      Paid models give sharper, more detailed remediation advice.
#
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
