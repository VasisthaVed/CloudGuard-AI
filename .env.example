# ================================================================
#  CloudGuard AI - Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit your .env file to Git!
# ================================================================

# ── AI Provider ─────────────────────────────────────────────────
# Choose your preferred engine:
#   - "litellm"     (Default) Support for 100+ providers via a single interface.
#   - "auto"        Automatically detects and uses the first available API key.
#   - "ollama"      Local/Offline AI (Requires Ollama running locally).
#   - "custom"      Private enterprise LLM endpoints.
#   - "anthropic"   Direct Anthropic SDK connection.
#   - "openai"      Direct OpenAI SDK connection.
#   - "gemini"      Direct Google Gemini SDK connection.
#   - "xai"         Direct xAI (Grok) SDK connection.
#   - "deepseek"    Direct DeepSeek SDK connection.
#   - "openrouter"  (Legacy alias) Routes through LiteLLM to OpenRouter.
#
AI_PROVIDER=litellm

# ── LiteLLM Configuration (Recommended) ──────────────────────────
# If using AI_PROVIDER=litellm, specify the model string here.
# Format: "provider/model-id"
# Examples: "anthropic/claude-3-5-sonnet-20240620", "openai/gpt-4o-mini", "google/gemini-pro"
LITELLM_MODEL=anthropic/claude-3-haiku-20240307

# ── API Keys ────────────────────────────────────────────────────
# Fill in the key(s) for the providers you intend to use.
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
XAI_API_KEY=your-xai-key-here
DEEPSEEK_API_KEY=your-deepseek-key-here
OPENROUTER_API_KEY=your-openrouter-key-here

# ── Ollama (Local AI) ───────────────────────────────────────────
# 1. Install Ollama from https://ollama.com
# 2. Run: ollama run llama3
# 3. Set AI_PROVIDER=ollama
OLLAMA_MODEL=llama3
# OLLAMA_HOST=http://localhost:11434 (Default)

# ── Enterprise Custom Endpoints ─────────────────────────────────
# Set AI_PROVIDER=custom
# CUSTOM_API_URL=https://private-ai.company.com/v1
# CUSTOM_API_KEY=your-internal-key
# CUSTOM_REQUEST_FORMAT=openai  # or "anthropic"

# ── Advanced Comparison Mode ────────────────────────────────────
# Set this to "true" to run findings against multiple models
# in parallel and have a Judge AI pick the absolute best one.
COMPARISON_MODE=false

# List of models to race against each other (if using OpenRouter/LiteLLM):
# COMPARISON_MODELS="anthropic/claude-3-haiku,openai/gpt-4o-mini,google/gemini-flash-1.5"

# The Judge model that evaluates the outputs:
# JUDGE_MODEL="openai/gpt-4o"
